version: 1

# ── Artifact Hint Patterns ─────────────────────────────────────
# Hint patterns guide Parity's artifact discovery — they are not filters.
# The Stage 1 agent always sees all changed files and can inspect any of them.
# Files matching these patterns are pre-loaded with before/after content for efficiency.

behavior_artifacts:
  paths:
    - "prompts/**"
    - "agents/**/*.md"
    - "config/agent_*.yaml"
  python_patterns:
    - "*_prompt"
    - "*_instruction"
    - "system_*"
    - "*_template"
  exclude:
    - "tests/**"
    - "*.test.yaml"
    - "docs/**"

# Guardrail artifacts: LLM judges, output classifiers, validators, rubrics, safety filters.
# Changes to these files alter how your agent evaluates or constrains its own outputs —
# often as significant as prompt changes but more rarely tested.
guardrail_artifacts:
  paths:
    - "judges/**"
    - "validators/**"
    - "guardrails/**"
    - "classifiers/**"
  python_patterns:
    - "*_judge*"
    - "*_validator*"
    - "*_classifier*"
    - "*_filter*"
    - "*_rubric*"

context:
  product: "context/product.md"
  users: "context/users.md"
  interactions: "context/interactions.md"
  good_examples: "context/good_examples.md"
  bad_examples: "context/bad_examples.md"
  traces_dir: "context/traces/"
  trace_max_samples: 20

# ── Platform Configuration ─────────────────────────────────────
# Configure the eval platform(s) you use. Only include platforms
# where you want Parity to read coverage and write probes.
platforms:
  langsmith:
    api_key_env: LANGSMITH_API_KEY

  # Uncomment to add Braintrust:
  # braintrust:
  #   api_key_env: BRAINTRUST_API_KEY
  #   org: "my-org"

  # Uncomment to add Arize Phoenix:
  # arize_phoenix:
  #   api_key_env: PHOENIX_API_KEY
  #   base_url: "https://app.phoenix.arize.com"

  # Uncomment to add Promptfoo (file-based):
  # promptfoo:
  #   config_path: "promptfooconfig.yaml"

mappings:
  - artifact: "prompts/citation_agent/system_prompt.md"
    platform: langsmith
    dataset: "citation-agent-evals"
  - artifact: "agents/planner/**"
    platform: langsmith
    dataset: "planner-regression"
  - artifact: "judges/citation_quality_rubric.md"
    platform: langsmith
    dataset: "citation-judge-calibration"
    eval_type: "judge_calibration"

embedding:
  model: "text-embedding-3-small"
  cache_path: ".parity/embedding_cache.db"
  # dimensions: 1536  # optional; use only if configuring a custom embedding backend

similarity:
  duplicate_threshold: 0.88
  boundary_threshold: 0.72

generation:
  proposal_probe_limit: 8
  candidate_probe_pool_limit: 20
  diversity_limit_per_gap: 2

approval:
  label: "parity:approve"

# ── Auto-Run (planned, not yet active in v1) ───────────────────
# Auto-run will trigger a scoped eval run after probe writeback and
# post results back to the merged PR. Not yet implemented.
# auto_run:
#   enabled: true
#   fail_on: "regression_guard"
#   notify: "pr_comment"

# ── Spend Caps ────────────────────────────────────────────────
# Optional total run spend cap. If omitted, Parity falls back to an internal default.
# This governs the full analysis budget Parity allocates across:
# - Stage 1 agent spend
# - Stage 2 agent spend
# - Stage 2 embedding spend
# - Stage 3 agent spend
spend:
  analysis_total_spend_cap_usd: 2.25

  # Advanced overrides. Set all four together only if you want manual control.
  # stage1_agent_cap_usd: 0.7875
  # stage2_agent_cap_usd: 0.45
  # stage2_embedding_cap_usd: 0.3375
  # stage3_agent_cap_usd: 0.675
