version: 2

# Hint patterns guide Stage 1 artifact discovery. They are not hard filters.
behavior_artifacts:
  paths:
    - "prompts/**"
    - "agents/**/*.md"
    - "config/agent_*.yaml"
  python_patterns:
    - "*_prompt"
    - "*_instruction"
    - "system_*"
    - "*_template"
  exclude:
    - "tests/**"
    - "*.test.yaml"
    - "docs/**"

guardrail_artifacts:
  paths:
    - "judges/**"
    - "validators/**"
    - "guardrails/**"
    - "classifiers/**"
  python_patterns:
    - "*_judge*"
    - "*_validator*"
    - "*_classifier*"
    - "*_filter*"
    - "*_rubric*"

context:
  product: "context/product.md"
  users: "context/users.md"
  interactions: "context/interactions.md"
  good_examples: "context/good_examples.md"
  bad_examples: "context/bad_examples.md"
  traces_dir: "context/traces/"
  trace_max_samples: 20

platforms:
  langsmith:
    api_key_env: LANGSMITH_API_KEY

  # braintrust:
  #   api_key_env: BRAINTRUST_API_KEY
  #   org: "my-org"

  # arize_phoenix:
  #   api_key_env: PHOENIX_API_KEY
  #   base_url: "https://app.phoenix.arize.com"

  # promptfoo:
  #   config_path: "promptfooconfig.yaml"

evals:
  discovery:
    repo_asset_globs:
      - "promptfooconfig.yaml"
      - "**/promptfooconfig.yaml"
      - "**/*promptfoo*.yaml"
      - "**/eval*.yaml"
      - "**/*eval*.py"
      - "**/*judge*.py"
      - "**/*scorer*.py"
    platform_discovery_order:
      - langsmith
      - promptfoo
    sample_limit_per_target: 20
    allow_repo_asset_discovery: true

  rules:
    - artifact: "prompts/citation_agent/system_prompt.md"
      preferred_platform: langsmith
      preferred_target: "citation-agent-evals"
      allowed_methods:
        - judge
        - hybrid
      preferred_methods:
        - hybrid
    - artifact: "agents/planner/**"
      preferred_platform: langsmith
      preferred_target: "planner-regression"
      allowed_methods:
        - deterministic
        - judge
    - artifact: "judges/citation_quality_rubric.md"
      preferred_platform: promptfoo
      preferred_target: "evals/promptfooconfig.yaml"
      allowed_methods:
        - judge
        - hybrid
      repo_asset_hints:
        - "evals/promptfooconfig.yaml"

  write:
    require_native_rendering: true
    min_render_confidence: 0.70
    create_missing_targets: false
    allow_review_only_exports: true

  evaluators:
    # Controls how strictly Parity confirms the target's existing evaluator regime
    # before reusing it. This does not enable evaluator creation or rebinding.
    formal_discovery_required: false
    allow_inference_fallback: true
    require_binding_verification: false
    min_binding_confidence: 0.85

embedding:
  model: "text-embedding-3-small"
  cache_path: ".parity/embedding_cache.db"

similarity:
  duplicate_threshold: 0.88
  boundary_threshold: 0.72

generation:
  proposal_limit: 8
  candidate_intent_pool_limit: 20
  diversity_limit_per_gap: 2

spend:
  analysis_total_spend_cap_usd: 2.50

  # Advanced overrides. Set all four together only if you want manual control.
  # stage1_agent_cap_usd: 0.75
  # stage2_agent_cap_usd: 0.45
  # stage2_embedding_cap_usd: 0.30
  # stage3_agent_cap_usd: 1.00
