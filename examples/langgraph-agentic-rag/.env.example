# Required: powers the Probegen stages (change detection, coverage analysis, probe generation)
ANTHROPIC_API_KEY=

# Required: the example LangGraph app uses OpenAI for all LLM calls and embeddings
OPENAI_API_KEY=

# Required: LANGSMITH_TRACING is enabled below, so this key is needed to authenticate tracing
# Also used later to seed the baseline eval dataset and write probes back after merge
LANGSMITH_API_KEY=

# Optional but recommended: silences USER_AGENT warnings when fetching the blog URLs
# Set this to any descriptive string identifying your requests (e.g., your project name or bot name)
USER_AGENT=probegen-langgraph-demo

# Enables tracing of all LLM calls to LangSmith (requires LANGSMITH_API_KEY above)
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=probegen-langgraph-demo
RAG_MODEL=gpt-4.1-mini
